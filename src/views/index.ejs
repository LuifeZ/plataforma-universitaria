<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Portal Acadêmico</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <%- include('partials/sidebar', { active: 'home' }) %>

  <main class="main">
    <div class="page-header">
      <div>
        <h2>Bem-vindo ao Portal Acadêmico</h2>
        <p>Gerencie alunos, professores e matérias em um só lugar.</p>
      </div>
    </div>

    <div class="row g-4">
      <div class="col-md-4">
        <a href="/alunos" class="module-card">
          <div class="module-icon" style="background:#eff6ff; color:#3b82f6;">
            <i class="bi bi-people"></i>
          </div>
          <h5>Alunos</h5>
          <p>Cadastre, edite e gerencie os alunos matriculados.</p>
          <span class="badge-count" style="background:#eff6ff; color:#3b82f6;">Ver todos</span>
        </a>
      </div>
      <div class="col-md-4">
        <a href="/professores" class="module-card">
          <div class="module-icon" style="background:#f0fdf4; color:#22c55e;">
            <i class="bi bi-person-badge"></i>
          </div>
          <h5>Professores</h5>
          <p>Gerencie os professores e suas matérias vinculadas.</p>
          <span class="badge-count" style="background:#f0fdf4; color:#22c55e;">Ver todos</span>
        </a>
      </div>
      <div class="col-md-4">
        <a href="/materias" class="module-card">
          <div class="module-icon" style="background:#fdf4ff; color:#a855f7;">
            <i class="bi bi-book"></i>
          </div>
          <h5>Matérias</h5>
          <p>Crie e organize as disciplinas oferecidas pela instituição.</p>
          <span class="badge-count" style="background:#fdf4ff; color:#a855f7;">Ver todas</span>
        </a>
      </div>
    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
