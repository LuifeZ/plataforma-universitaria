<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= aluno ? 'Editar Aluno' : 'Novo Aluno' %> — Portal Acadêmico</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <%- include('../partials/sidebar', { active: 'alunos' }) %>

  <main class="main">
    <div class="breadcrumb-bar">
      <a href="/">Início</a>
      <i class="bi bi-chevron-right"></i>
      <a href="/alunos">Alunos</a>
      <i class="bi bi-chevron-right"></i>
      <span><%= aluno ? 'Editar Aluno' : 'Novo Aluno' %></span>
    </div>

    <div class="page-header">
      <div>
        <h2><%= aluno ? 'Editar Aluno' : 'Novo Aluno' %></h2>
        <p><%= aluno ? 'Atualize os dados do aluno.' : 'Preencha os dados para cadastrar um novo aluno.' %></p>
      </div>
    </div>

    <div class="form-card">
      <div class="form-card-header">
        <div class="header-icon" style="background:#eff6ff; color:#3b82f6;"><i class="bi bi-people"></i></div>
        <div>
          <h5>Dados do Aluno</h5>
          <span>Campos com <span style="color:#ef4444">*</span> são obrigatórios</span>
        </div>
      </div>

      <form action="<%= aluno ? '/alunos/' + aluno.id + '?_method=PUT' : '/alunos' %>" method="POST">
        <div class="form-body">

          <div class="section-title">Informações pessoais</div>

          <div class="form-group">
            <label>Nome completo <span class="required">*</span></label>
            <input
              type="text"
              name="nome"
              class="form-control"
              placeholder="Ex: Pedro Santos"
              value="<%= aluno ? aluno.nome : '' %>"
              required
            />
          </div>

          <div class="row g-3">
            <div class="col-md-6">
              <div class="form-group">
                <label>Matrícula <span class="required">*</span></label>
                <input
                  type="text"
                  name="matricula"
                  class="form-control"
                  placeholder="Ex: 2024001"
                  value="<%= aluno ? aluno.matricula : '' %>"
                  required
                />
              </div>
            </div>
            <div class="col-md-6">
              <div class="form-group">
                <label>E-mail <span class="required">*</span></label>
                <input
                  type="email"
                  name="email"
                  class="form-control"
                  placeholder="aluno@email.com"
                  value="<%= aluno ? aluno.email : '' %>"
                  required
                />
              </div>
            </div>
          </div>

        </div>

        <div class="form-actions">
          <button type="submit" class="btn-save">
            <i class="bi bi-check-lg"></i>
            <%= aluno ? 'Salvar alterações' : 'Cadastrar aluno' %>
          </button>
          <a href="/alunos" class="btn-cancel">Cancelar</a>
        </div>
      </form>
    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
