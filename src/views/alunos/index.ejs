<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Alunos — Portal Acadêmico</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <%- include('../partials/sidebar', { active: 'alunos' }) %>

  <main class="main">
    <div class="page-header">
      <div>
        <h2>Alunos</h2>
        <p>Gerencie os alunos matriculados no sistema.</p>
      </div>
      <a href="/alunos/novo" class="btn-new">
        <i class="bi bi-plus-lg"></i> Novo Aluno
      </a>
    </div>

    <div class="stats-bar">
      <div class="stat-card">
        <div class="stat-icon" style="background:#eff6ff; color:#3b82f6;"><i class="bi bi-people"></i></div>
        <div>
          <strong><%= alunos.length %></strong>
          <span>Total de alunos</span>
        </div>
      </div>
    </div>

    <div class="table-card">
      <div class="table-toolbar">
        <div class="search-box">
          <i class="bi bi-search"></i>
          <input type="text" id="searchInput" placeholder="Buscar aluno..." onkeyup="filtrarTabela()" />
        </div>
      </div>

      <table id="tabelaAlunos">
        <thead>
          <tr>
            <th>Aluno</th>
            <th>E-mail</th>
            <th>Matrícula</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (alunos.length > 0) { %>
            <% alunos.forEach(aluno => { %>
            <tr>
              <td>
                <div class="cell-flex">
                  <div class="avatar" style="background: linear-gradient(135deg, #3b82f6, #2563eb);">
                    <%= aluno.nome.charAt(0).toUpperCase() %>
                  </div>
                  <%= aluno.nome %>
                </div>
              </td>
              <td><%= aluno.email %></td>
              <td><%= aluno.matricula %></td>
              <td>
                <a href="/alunos/<%= aluno.id %>/editar" class="btn-action btn-edit">
                  <i class="bi bi-pencil"></i> Editar
                </a>
                <form action="/alunos/<%= aluno.id %>?_method=DELETE" method="POST" style="display:inline">
                  <button type="submit" class="btn-action btn-delete" onclick="return confirm('Excluir este aluno?')">
                    <i class="bi bi-trash"></i> Excluir
                  </button>
                </form>
              </td>
            </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="4">
                <div class="empty-state">
                  <i class="bi bi-people"></i>
                  <p>Nenhum aluno cadastrado ainda.<br>Clique em <strong>Novo Aluno</strong> para começar.</p>
                </div>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </main>

  <script>
    function filtrarTabela() {
      const input = document.getElementById('searchInput').value.toLowerCase();
      const rows = document.querySelectorAll('#tabelaAlunos tbody tr');
      rows.forEach(row => {
        row.style.display = row.textContent.toLowerCase().includes(input) ? '' : 'none';
      });
    }
  </script>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
