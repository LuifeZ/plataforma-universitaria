<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= professor ? 'Editar Professor' : 'Novo Professor' %> — Portal Acadêmico</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <%- include('../partials/sidebar', { active: 'professores' }) %>

  <main class="main">
    <div class="breadcrumb-bar">
      <a href="/">Início</a>
      <i class="bi bi-chevron-right"></i>
      <a href="/professores">Professores</a>
      <i class="bi bi-chevron-right"></i>
      <span><%= professor ? 'Editar Professor' : 'Novo Professor' %></span>
    </div>

    <div class="page-header">
      <div>
        <h2><%= professor ? 'Editar Professor' : 'Novo Professor' %></h2>
        <p><%= professor ? 'Atualize os dados do professor.' : 'Preencha os dados para cadastrar um novo professor.' %></p>
      </div>
    </div>

    <div class="form-card">
      <div class="form-card-header">
        <div class="header-icon" style="background:#f0fdf4; color:#22c55e;"><i class="bi bi-person-badge"></i></div>
        <div>
          <h5>Dados do Professor</h5>
          <span>Campos com <span style="color:#ef4444">*</span> são obrigatórios</span>
        </div>
      </div>

      <form action="<%= professor ? '/professores/' + professor.id + '?_method=PUT' : '/professores' %>" method="POST">
        <div class="form-body">

          <div class="section-title">Informações pessoais</div>

          <div class="form-group">
            <label>Nome completo <span class="required">*</span></label>
            <input
              type="text"
              name="nome"
              class="form-control"
              placeholder="Ex: Maria Silva"
              value="<%= professor ? professor.nome : '' %>"
              required
            />
          </div>

          <div class="row g-3">
            <div class="col-md-6">
              <div class="form-group">
                <label>CPF</label>
                <input
                  type="text"
                  name="cpf"
                  class="form-control"
                  placeholder="000.000.000-00"
                  value="<%= professor ? (professor.cpf || '') : '' %>"
                  maxlength="14"
                />
              </div>
            </div>
            <div class="col-md-6">
              <div class="form-group">
                <label>E-mail <span class="required">*</span></label>
                <input
                  type="email"
                  name="email"
                  class="form-control"
                  placeholder="professor@email.com"
                  value="<%= professor ? professor.email : '' %>"
                  required
                />
              </div>
            </div>
          </div>

          <hr class="form-divider" />
          <div class="section-title">Vínculo acadêmico</div>

          <div class="form-group">
            <label>Disciplina(s)</label>
            <input
              type="text"
              name="disciplinas"
              class="form-control"
              placeholder="Ex: Matemática, Física"
              value="<%= professor ? (professor.disciplinas || '') : '' %>"
            />
            <p class="form-hint">Separe as disciplinas por vírgula.</p>
          </div>

        </div>

        <div class="form-actions">
          <button type="submit" class="btn-save">
            <i class="bi bi-check-lg"></i>
            <%= professor ? 'Salvar alterações' : 'Cadastrar professor' %>
          </button>
          <a href="/professores" class="btn-cancel">Cancelar</a>
        </div>
      </form>
    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
