<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= materia ? 'Editar Matéria' : 'Nova Matéria' %> — Portal Acadêmico</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <%- include('../partials/sidebar', { active: 'materias' }) %>

  <main class="main">
    <div class="breadcrumb-bar">
      <a href="/">Início</a>
      <i class="bi bi-chevron-right"></i>
      <a href="/materias">Matérias</a>
      <i class="bi bi-chevron-right"></i>
      <span><%= materia ? 'Editar Matéria' : 'Nova Matéria' %></span>
    </div>

    <div class="page-header">
      <div>
        <h2><%= materia ? 'Editar Matéria' : 'Nova Matéria' %></h2>
        <p><%= materia ? 'Atualize os dados da matéria.' : 'Preencha os dados para cadastrar uma nova matéria.' %></p>
      </div>
    </div>

    <div class="form-card">
      <div class="form-card-header">
        <div class="header-icon" style="background:#fdf4ff; color:#a855f7;"><i class="bi bi-book"></i></div>
        <div>
          <h5>Dados da Matéria</h5>
          <span>Campos com <span style="color:#ef4444">*</span> são obrigatórios</span>
        </div>
      </div>

      <form action="<%= materia ? '/materias/' + materia.id + '?_method=PUT' : '/materias' %>" method="POST">
        <div class="form-body">

          <div class="section-title">Informações da disciplina</div>

          <div class="form-group">
            <label>Nome da matéria <span class="required">*</span></label>
            <input
              type="text"
              name="nome"
              class="form-control"
              placeholder="Ex: Matemática Básica"
              value="<%= materia ? materia.nome : '' %>"
              required
            />
          </div>

          <div class="row g-3">
            <div class="col-md-6">
              <div class="form-group">
                <label>Carga horária (horas)</label>
                <input
                  type="number"
                  name="carga_horaria"
                  class="form-control"
                  placeholder="Ex: 60"
                  value="<%= materia ? (materia.carga_horaria || '') : '' %>"
                />
              </div>
            </div>
            <div class="col-md-6">
              <div class="form-group">
                <label>Professor responsável</label>
                <select name="professor_id" class="form-control">
                  <option value="">Selecione um professor</option>
                  <% professores.forEach(professor => { %>
                    <option value="<%= professor.id %>" <%= (materia && materia.professor_id === professor.id) ? 'selected' : '' %>>
                      <%= professor.nome %>
                    </option>
                  <% }) %>
                </select>
              </div>
            </div>
          </div>

        </div>

        <div class="form-actions">
          <button type="submit" class="btn-save">
            <i class="bi bi-check-lg"></i>
            <%= materia ? 'Salvar alterações' : 'Cadastrar matéria' %>
          </button>
          <a href="/materias" class="btn-cancel">Cancelar</a>
        </div>
      </form>
    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
